// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  telegramId BigInt @unique
  username  String?
  firstName String?
  lastName  String?
  isAdmin   Boolean @default(false)
  isAgeVerified Boolean @default(false)
  ageVerifiedAt DateTime?
  language  String @default("uk")
  theme     String @default("light")
  createdAt DateTime @default(now())

  orders       Order[]
  recommendations Recommendation[]

  @@index([telegramId])
}

model Product {
  id              Int     @id @default(autoincrement())
  name            String
  nameEn          String
  namePl          String
  description     String
  descriptionEn   String
  descriptionPl   String
  price           Float
  category        String
  brand           String?
  emoji           String?
  nicotineFree    Boolean @default(false)
  flavorProfile   String?
  imageUrl        String?
  images          Json?
  inStock         Boolean @default(true)
  stockQuantity   Int     @default(0)
  rating          Float   @default(0)
  createdAt       DateTime @default(now())

  orders        OrderProduct[]
  recommendations Recommendation[]

  @@index([name])
  @@index([category])
}

model Order {
  id            Int     @id @default(autoincrement())
  telegramId    BigInt
  orderNumber   String  @unique
  status        String  @default("pending")
  isPaid        Boolean @default(false)
  paymentMethod String?
  totalPrice    Float
  promocode     String?
  discountAmount Float @default(0)
  deliveryAddress String?
  pickupLocation String?
  customerNotes String?
  adminNotes    String?
  items         Json
  screenshotFilename String?
  trackingNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [telegramId], references: [telegramId])
  products OrderProduct[]

  @@index([telegramId])
  @@index([orderNumber])
}

model Image {
  id        Int      @id @default(autoincrement())
  filename  String   @unique
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())

  @@index([filename])
}

model OrderProduct {
  id        Int @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float

  order   Order @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model PromoCode {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  discountType String
  discountValue Float
  maxUses     Int?
  usedCount   Int     @default(0)
  isActive    Boolean @default(true)
  minPurchase Float?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  @@index([code])
}

model Recommendation {
  id        Int     @id @default(autoincrement())
  userId    Int
  productId Int
  score     Float
  reason    String?
  createdAt DateTime @default(now())

  user    User @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
}

model Message {
  id                 Int      @id @default(autoincrement())
  senderTelegramId   BigInt
  receiverTelegramId BigInt
  text               String
  direction          String   // "client_to_admin", "admin_to_client", "system"
  messageType        String   @default("text") // "text", "photo", "order", "payment", "system"
  metadata           Json?    // extra data (imageUrl, orderId, etc.)
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([senderTelegramId])
  @@index([receiverTelegramId])
  @@index([createdAt])
}
