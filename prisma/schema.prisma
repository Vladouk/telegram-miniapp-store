// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  telegramId BigInt @unique
  username  String?
  firstName String?
  lastName  String?
  isAdmin   Boolean @default(false)
  isAgeVerified Boolean @default(false)
  ageVerifiedAt DateTime?
  language  String @default("uk")
  theme     String @default("light")
  referralCode String? @unique
  referralCodeUsed String? // The referral code used by this user during signup
  referralRewardRemaining Float @default(0)
  referrerTelegramId BigInt? // Who referred this user
  createdAt DateTime @default(now())

  orders       Order[]
  recommendations Recommendation[]
  referralRewardsReceived ReferralReward[] @relation("referrer")
  referralRewardsGiven ReferralReward[] @relation("referred")

  @@index([telegramId])
  @@index([referralCode])
  @@index([referralCodeUsed])
  @@index([referrerTelegramId])
}

model Product {
  id              Int     @id @default(autoincrement())
  name            String
  nameEn          String
  namePl          String
  description     String
  descriptionEn   String
  descriptionPl   String
  price           Float
  category        String
  brand           String?
  emoji           String?
  nicotineFree    Boolean @default(false)
  flavorProfile   String?
  imageUrl        String?
  inStock         Boolean @default(true)
  stockQuantity   Int     @default(0)
  rating          Float   @default(0)
  createdAt       DateTime @default(now())

  orders        OrderProduct[]
  recommendations Recommendation[]

  @@index([name])
  @@index([category])
}

model Order {
  id            Int     @id @default(autoincrement())
  telegramId    BigInt
  orderNumber   String  @unique
  status        String  @default("pending")
  paymentMethod String?
  totalPrice    Float
  promocode     String?
  discountAmount Float @default(0)
  deliveryAddress String?
  pickupLocation String?
  customerNotes String?
  adminNotes    String?
  items         Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [telegramId], references: [telegramId])
  products OrderProduct[]

  @@index([telegramId])
  @@index([orderNumber])
}

model OrderProduct {
  id        Int @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float

  order   Order @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model PromoCode {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  discountType String
  discountValue Float
  maxUses     Int?
  usedCount   Int     @default(0)
  isActive    Boolean @default(true)
  minPurchase Float?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  @@index([code])
}

model Recommendation {
  id        Int     @id @default(autoincrement())
  userId    Int
  productId Int
  score     Float
  reason    String?
  createdAt DateTime @default(now())

  user    User @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
}

model ReferralReward {
  id              Int     @id @default(autoincrement())
  referrerTelegramId BigInt
  referredTelegramId BigInt
  rewardAmount    Float @default(10)
  status          String @default("pending")
  createdAt       DateTime @default(now())
  usedAt          DateTime?

  referrer User @relation("referrer", fields: [referrerTelegramId], references: [telegramId])
  referred User @relation("referred", fields: [referredTelegramId], references: [telegramId])

  @@index([referrerTelegramId])
  @@index([referredTelegramId])
  @@unique([referrerTelegramId, referredTelegramId])
}
